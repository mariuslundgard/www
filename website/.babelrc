{
  "env": {
    "browser": {
      "presets": [
        [
          "@babel/preset-env",
          {
            "targets": {
              "browsers": [">0.25%", "not ie 11", "not op_mini all"]
            }
          }
        ],
        "@babel/preset-typescript"
      ]
    },

    "server": {
      "presets": [
        [
          "@babel/preset-env",
          {
            "targets": {
              "node": "current"
            }
          }
        ],
        "@babel/preset-typescript"
      ]
    }
  }
}
